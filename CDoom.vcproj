<?xml version="1.0" encoding="Windows-1252"?>
<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.10"
	Name="GZDoom"
	SccProjectName=""
	SccLocalPath="">
	<Platforms>
		<Platform
			Name="Win32"/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="Optimized Debug|Win32"
			OutputDirectory=".\CDoom___Win32_Optimized_Debug"
			IntermediateDirectory=".\CDoom___Win32_Optimized_Debug"
			ConfigurationType="1"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE"
			CharacterSet="2">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/O2"
				Optimization="2"
				InlineFunctionExpansion="1"
				AdditionalIncludeDirectories="flac,.,sound,win32,zlib,g_shared,g_raven,g_heretic,g_doom,g_strife,g_hexen,private"
				PreprocessorDefinitions="DEBUG;_DEBUG;NOASM;WIN32;_WINDOWS;HAVE_STRUPR;HAVE_FILELENGTH;SILENT_INSTANT_FLOORS"
				StringPooling="TRUE"
				RuntimeLibrary="2"
				EnableFunctionLevelLinking="TRUE"
				UsePrecompiledHeader="0"
				PrecompiledHeaderThrough=""
				PrecompiledHeaderFile=".\CDoom___Win32_Optimized_Debug/CDoom.pch"
				AssemblerOutput="4"
				AssemblerListingLocation=".\CDoom___Win32_Optimized_Debug/"
				ObjectFile=".\CDoom___Win32_Optimized_Debug/"
				ProgramDataBaseFileName=".\CDoom___Win32_Optimized_Debug/"
				BrowseInformation="1"
				WarningLevel="3"
				SuppressStartupBanner="TRUE"
				DebugInformationFormat="3"
				CallingConvention="2"
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="opengl32.lib glu32.lib dsound.lib dxguid.lib ddraw.lib dinput.lib fmodvc.lib winmm.lib wsock32.lib comctl32.lib devil.lib"
				OutputFile=".\CDoom___Win32_Optimized_Debug/CDoom.exe"
				LinkIncremental="1"
				SuppressStartupBanner="TRUE"
				GenerateDebugInformation="TRUE"
				ProgramDatabaseFile=".\CDoom___Win32_Optimized_Debug/CDoom.pdb"
				GenerateMapFile="TRUE"
				MapFileName=".\CDoom___Win32_Optimized_Debug/CDoom.map"
				SubSystem="2"
				TargetMachine="1"/>
			<Tool
				Name="VCMIDLTool"
				PreprocessorDefinitions="NDEBUG"
				MkTypLibCompatible="TRUE"
				SuppressStartupBanner="TRUE"
				TargetEnvironment="1"
				TypeLibraryName=".\CDoom___Win32_Optimized_Debug/CDoom.tlb"
				HeaderFileName=""/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"
				PreprocessorDefinitions="NDEBUG"
				Culture="1031"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
